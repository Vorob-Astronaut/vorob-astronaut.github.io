---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Wulong Apps LLC — Subscription Products">
  <!-- Hero -->
  <section class="relative min-h-[75vh] md:min-h-screen flex items-center justify-center overflow-hidden py-24 md:py-40">
    <!-- Background -->
    <div class="absolute inset-0 bg-dark">
      <div class="absolute w-[600px] h-[600px] rounded-full -top-[20%] -right-[10%] bg-amber/15 blur-[80px]" style="animation: orbFloat 12s ease-in-out infinite;"></div>
      <div class="absolute w-[400px] h-[400px] rounded-full -bottom-[10%] -left-[5%] bg-amber/8 blur-[80px]" style="animation: orbFloat 16s ease-in-out infinite reverse;"></div>
      <div class="absolute inset-0" style="background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 60px 60px; mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 20%, transparent 70%); -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 20%, transparent 70%);"></div>
    </div>
    <!-- Content -->
    <div class="relative z-10 text-center text-white max-w-6xl mx-auto px-6 md:px-8">
      <div class="animate-in inline-flex items-center gap-2.5 text-[0.78rem] font-semibold tracking-widest uppercase text-white/60 mb-9 px-6 py-2.5 border border-white/8 rounded-full bg-white/4 backdrop-blur-sm">
        <span class="w-[7px] h-[7px] rounded-full bg-amber shadow-[0_0_8px_rgba(180,83,9,0.6)]" style="animation: dotPulse 2.5s ease-in-out infinite;"></span>
        Digital Products
      </div>
      <h1 class="animate-in animate-in-delay-1 font-display text-[clamp(2.4rem,6.5vw,5rem)] font-normal leading-[1.1] tracking-tight mb-7">
        Products built<br/>for <em class="italic text-amber">real people</em>
      </h1>
      <p class="animate-in animate-in-delay-2 text-base md:text-lg text-white/50 max-w-lg mx-auto mb-10 md:mb-12 font-normal leading-relaxed px-2">At Wulong Apps LLC, we create digital products that help people improve their health, career, and lifestyle with simple daily routines.</p>
      <div class="animate-in animate-in-delay-3 flex gap-3 md:gap-4 justify-center flex-wrap">
        <a href="#products" class="inline-flex items-center gap-2 px-7 md:px-9 py-3 md:py-3.5 rounded-full bg-amber text-white font-semibold text-sm md:text-[0.95rem] no-underline shadow-[0_4px_24px_rgba(180,83,9,0.35)] hover:bg-amber-hover hover:-translate-y-0.5 transition-all">
          Explore Products
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </a>
        <a href="mailto:contact@wulongllc.com" class="inline-flex items-center gap-2 px-7 md:px-9 py-3 md:py-3.5 rounded-full border border-white/15 text-white/80 font-semibold text-sm md:text-[0.95rem] no-underline hover:border-white/40 hover:bg-white/5 hover:text-white hover:-translate-y-0.5 transition-all">Get in Touch</a>
      </div>
    </div>
    <!-- Bottom fade -->
    <div class="absolute bottom-0 inset-x-0 h-28 bg-gradient-to-t from-bg to-transparent z-10"></div>
  </section>

  <!-- Trust Strip -->
  <section class="relative z-20 -mt-12 px-6 md:px-8">
    <div class="max-w-3xl mx-auto bg-surface rounded-2xl shadow-xl border border-line-subtle py-7 px-8 md:px-12 flex flex-col md:flex-row items-stretch md:items-center gap-5 md:gap-0">
      <!-- Item 1 -->
      <div class="flex items-center gap-3.5 flex-1">
        <div class="w-11 h-11 rounded-xl bg-bg-warm text-amber flex items-center justify-center shrink-0">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div>
          <span class="block font-semibold text-sm text-ink">Secure Payments</span>
          <span class="block text-xs text-ink-faint mt-px">Powered by Stripe</span>
        </div>
      </div>
      <!-- Divider -->
      <div class="hidden md:block w-px h-10 bg-line mx-8 shrink-0"></div>
      <div class="block md:hidden w-full h-px bg-line"></div>
      <!-- Item 2 -->
      <div class="flex items-center gap-3.5 flex-1">
        <div class="w-11 h-11 rounded-xl bg-bg-warm text-amber flex items-center justify-center shrink-0">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </div>
        <div>
          <span class="block font-semibold text-sm text-ink">24/7 Support</span>
          <span class="block text-xs text-ink-faint mt-px">Real humans, fast replies</span>
        </div>
      </div>
      <!-- Divider -->
      <div class="hidden md:block w-px h-10 bg-line mx-8 shrink-0"></div>
      <div class="block md:hidden w-full h-px bg-line"></div>
      <!-- Item 3 -->
      <div class="flex items-center gap-3.5 flex-1">
        <div class="w-11 h-11 rounded-xl bg-bg-warm text-amber flex items-center justify-center shrink-0">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
        </div>
        <div>
          <span class="block font-semibold text-sm text-ink">Cancel Anytime</span>
          <span class="block text-xs text-ink-faint mt-px">No lock-in contracts</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Products & Pricing -->
  <section class="py-24 md:py-28" id="products">
    <div class="max-w-6xl mx-auto px-6 md:px-8">
      <div class="text-center mb-14">
        <span class="text-[0.8rem] font-semibold tracking-[0.15em] uppercase text-amber block mb-4">Our Products</span>
        <h2 class="font-display text-[2.6rem] font-normal mb-4 tracking-tight leading-tight">Transparent Pricing</h2>
        <p class="text-lg text-ink-soft">Full recurring rates for every plan. No hidden fees, no surprises on your statement.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-7">
        <!-- Tinnitus Relief -->
        <div class="group relative bg-surface rounded-2xl border border-line-subtle overflow-hidden hover:border-amber/20 hover:shadow-xl hover:-translate-y-1.5 transition-all duration-400">
          <div class="absolute top-0 inset-x-0 h-28 bg-gradient-to-b from-amber/4 to-transparent pointer-events-none"></div>
          <div class="relative pt-7 md:pt-9 pb-0 px-5 md:px-9 text-center">
            <div class="w-[60px] h-[60px] rounded-2xl bg-gradient-to-br from-amber-light to-amber-light/40 text-amber flex items-center justify-center mx-auto mb-5 border border-amber/10">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
            </div>
            <h3 class="font-display text-xl mb-1.5">Tinnitus Relief Program</h3>
            <a href="https://tinnitusrelief.io" class="text-ink-faint text-[0.82rem] font-medium tracking-wide hover:text-amber transition-colors no-underline" target="_blank" rel="noopener">tinnitusrelief.io &#x2197;</a>
          </div>
          <div class="px-5 md:px-9 pt-6">
            <div class="flex items-center justify-between py-[18px] border-b border-line-subtle">
              <div class="flex items-center gap-3">
                <span class="hidden sm:inline-block text-[0.65rem] font-bold tracking-wider uppercase px-2.5 py-1 rounded-md bg-bg text-ink-faint min-w-[64px] text-center">Monthly</span>
                <span class="font-medium text-[0.92rem] text-ink">1-Month Plan</span>
              </div>
              <div class="flex items-baseline gap-0.5">
                <span class="font-display text-2xl md:text-3xl text-ink leading-none">$49<span class="text-base">.99</span></span>
                <span class="text-[0.8rem] text-ink-faint font-medium ml-0.5">/month</span>
              </div>
            </div>
            <div class="flex items-center justify-between py-[18px]">
              <div class="flex items-center gap-3">
                <span class="hidden sm:inline-block text-[0.65rem] font-bold tracking-wider uppercase px-2.5 py-1 rounded-md bg-amber-light text-amber min-w-[64px] text-center">Quarterly</span>
                <span class="font-medium text-[0.92rem] text-ink">3-Month Plan</span>
              </div>
              <div class="flex items-baseline gap-0.5">
                <span class="font-display text-2xl md:text-3xl text-ink leading-none">$99<span class="text-base">.00</span></span>
                <span class="text-[0.8rem] text-ink-faint font-medium ml-0.5">/3 mo</span>
              </div>
            </div>
          </div>
          <div class="flex items-start gap-2.5 px-5 md:px-9 py-5 mx-5 md:mx-9 border-t border-line-subtle text-[0.78rem] text-ink-faint leading-snug">
            <svg class="shrink-0 mt-0.5 opacity-50" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            <span>Auto-renews until cancelled. Prices are full rates after any intro offer.</span>
          </div>
        </div>

        <!-- Remote Jobs Board -->
        <div class="group relative bg-surface rounded-2xl border border-line-subtle overflow-hidden hover:border-amber/20 hover:shadow-xl hover:-translate-y-1.5 transition-all duration-400">
          <div class="absolute top-0 inset-x-0 h-28 bg-gradient-to-b from-amber/4 to-transparent pointer-events-none"></div>
          <div class="relative pt-7 md:pt-9 pb-0 px-5 md:px-9 text-center">
            <div class="w-[60px] h-[60px] rounded-2xl bg-gradient-to-br from-amber-light to-amber-light/40 text-amber flex items-center justify-center mx-auto mb-5 border border-amber/10">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            </div>
            <h3 class="font-display text-xl mb-1.5">Remote Jobs Board</h3>
            <a href="https://remotejobsboard.io" class="text-ink-faint text-[0.82rem] font-medium tracking-wide hover:text-amber transition-colors no-underline" target="_blank" rel="noopener">remotejobsboard.io &#x2197;</a>
          </div>
          <div class="px-5 md:px-9 pt-6">
            <div class="flex items-center justify-between py-[18px] border-b border-line-subtle">
              <div class="flex items-center gap-3">
                <span class="hidden sm:inline-block text-[0.65rem] font-bold tracking-wider uppercase px-2.5 py-1 rounded-md bg-bg text-ink-faint min-w-[64px] text-center">Weekly</span>
                <span class="font-medium text-[0.92rem] text-ink">1-Week Plan</span>
              </div>
              <div class="flex items-baseline gap-0.5">
                <span class="font-display text-2xl md:text-3xl text-ink leading-none">$14<span class="text-base">.99</span></span>
                <span class="text-[0.8rem] text-ink-faint font-medium ml-0.5">/week</span>
              </div>
            </div>
            <div class="flex items-center justify-between py-[18px] border-b border-line-subtle">
              <div class="flex items-center gap-3">
                <span class="hidden sm:inline-block text-[0.65rem] font-bold tracking-wider uppercase px-2.5 py-1 rounded-md bg-bg text-ink-faint min-w-[64px] text-center">Monthly</span>
                <span class="font-medium text-[0.92rem] text-ink">1-Month Plan</span>
              </div>
              <div class="flex items-baseline gap-0.5">
                <span class="font-display text-2xl md:text-3xl text-ink leading-none">$39<span class="text-base">.99</span></span>
                <span class="text-[0.8rem] text-ink-faint font-medium ml-0.5">/month</span>
              </div>
            </div>
            <div class="flex items-center justify-between py-[18px]">
              <div class="flex items-center gap-3">
                <span class="hidden sm:inline-block text-[0.65rem] font-bold tracking-wider uppercase px-2.5 py-1 rounded-md bg-amber-light text-amber min-w-[64px] text-center">Quarterly</span>
                <span class="font-medium text-[0.92rem] text-ink">3-Month Plan</span>
              </div>
              <div class="flex items-baseline gap-0.5">
                <span class="font-display text-2xl md:text-3xl text-ink leading-none">$89<span class="text-base">.99</span></span>
                <span class="text-[0.8rem] text-ink-faint font-medium ml-0.5">/3 mo</span>
              </div>
            </div>
          </div>
          <div class="flex items-start gap-2.5 px-5 md:px-9 py-5 mx-5 md:mx-9 border-t border-line-subtle text-[0.78rem] text-ink-faint leading-snug">
            <svg class="shrink-0 mt-0.5 opacity-50" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            <span>Auto-renews until cancelled. Prices are full rates after any intro offer.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="relative py-28 md:py-32 overflow-hidden" id="contact">
    <!-- Background -->
    <div class="absolute inset-0 bg-dark">
      <div class="absolute w-[500px] h-[500px] rounded-full -bottom-[20%] -right-[10%] bg-amber/10 blur-[100px]"></div>
    </div>
    <!-- Content -->
    <div class="relative z-10 max-w-6xl mx-auto px-6 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Left -->
        <div class="text-white text-center lg:text-left">
          <span class="text-[0.78rem] font-semibold tracking-[0.18em] uppercase text-amber block mb-5">Customer Support</span>
          <h2 class="font-display text-[2.8rem] font-normal leading-[1.15] tracking-tight mb-5">We're here<br class="hidden lg:block"/> whenever you<br class="hidden lg:block"/> need us</h2>
          <p class="text-base text-white/45 leading-relaxed">Questions about billing, your subscription, or anything else? Our team responds to every email personally.</p>
        </div>
        <!-- Right - Contact Card -->
        <div class="bg-white/4 border border-white/8 rounded-2xl p-6 md:p-9 backdrop-blur-md">
          <div class="flex items-center gap-2.5 text-[0.82rem] font-semibold text-white/50 tracking-wider uppercase mb-5">
            <span class="w-2 h-2 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.5)]" style="animation: dotPulse 2.5s ease-in-out infinite;"></span>
            24/7 Email Support
          </div>
          <a href="mailto:contact@wulongllc.com" class="block font-display text-2xl text-white no-underline mb-7 pb-6 border-b border-white/8 hover:text-amber transition-colors">
            contact@wulongllc.com
          </a>
          <div class="flex flex-col gap-3.5 mb-7">
            <div class="flex items-center gap-3 text-[0.9rem] text-white/55">
              <svg class="text-amber shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Subscription &amp; billing questions
            </div>
            <div class="flex items-center gap-3 text-[0.9rem] text-white/55">
              <svg class="text-amber shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Cancel or modify your plan
            </div>
            <div class="flex items-center gap-3 text-[0.9rem] text-white/55">
              <svg class="text-amber shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Refund requests
            </div>
            <div class="flex items-center gap-3 text-[0.9rem] text-white/55">
              <svg class="text-amber shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              General inquiries
            </div>
          </div>
          <a href="mailto:contact@wulongllc.com" class="w-full inline-flex items-center justify-center gap-2 px-9 py-4 rounded-full bg-amber text-white font-semibold text-[0.95rem] no-underline shadow-[0_4px_16px_rgba(180,83,9,0.2)] hover:bg-amber-hover hover:-translate-y-0.5 transition-all">
            Send Us an Email
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
